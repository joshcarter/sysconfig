;;; dotemacs --- Josh's Emacs configuration  -*- lexical-binding: t; -*-

;; Requires Emacs 29+ (for use-package, eglot, etc.)

;;; Directories

(defvar home-dir (concat (expand-file-name "~") "/"))

(defvar emacs-dir
  (cond
   ((file-exists-p (concat home-dir "Library/SysConfig/emacs"))
    (concat home-dir "Library/SysConfig/emacs"))
   ((file-exists-p (concat home-dir "sysconfig/emacs"))
    (concat home-dir "sysconfig/emacs"))
   (t (error "Cannot find emacs config directory"))))

(push emacs-dir load-path)

;;; Package management (MELPA + use-package)

(require 'package)
(add-to-list 'package-archives '("melpa" . "https://melpa.org/packages/") t)
(package-initialize)

;; Bootstrap: refresh archive on first run so use-package can find packages
(unless package-archive-contents
  (package-refresh-contents))

(require 'use-package-ensure)
(setq use-package-always-ensure t)

;;; Load personal functions

(load-file (concat emacs-dir "/josh-addons.el"))

;;; Defaults

(setq inhibit-splash-screen t)
(line-number-mode 1)
(column-number-mode 1)

(setq-default c-basic-offset 4)
(setq-default tab-width 4)
(setq-default indent-tabs-mode nil)

(setq major-mode 'text-mode)
(add-hook 'text-mode-hook
  (function (lambda ()
    "jet's additions to text-mode"
    (setq tab-width 2)
    (turn-on-auto-fill))))

(setq sentence-end "[.?!][]\"')]*\\($\\|\t\\| \\)[ \t\n]*")
(setq sentence-end-double-space nil)
(setq truncate-partial-width-windows nil)

;;; Backup configuration

(defconst use-backup-dir t)
(setq backup-directory-alist (quote ((".*" . "~/Backup/")))
      version-control t
      kept-new-versions 2
      kept-old-versions 2
      delete-old-versions t
      history-delete-duplicates t
      history-length 100
      dired-listing-switches "-l"
      dired-recursive-deletes 'top
      dired-recursive-copies 'top
      backup-by-copying-when-linked t)

;;; Custom file (keep M-x customize output out of dotemacs)

(setq custom-file (concat emacs-dir "/custom.el"))
(when (file-exists-p custom-file)
  (load custom-file))

;;; Theme

(use-package gruvbox-theme
  :config
  (load-theme 'gruvbox-dark-medium t))

;;; Completion (company-mode integrates with eglot automatically)

(use-package company
  :hook (after-init . global-company-mode))

;;; Which-key (keybinding discoverability)

(use-package which-key
  :config
  (which-key-mode))

;;; xterm-color

(use-package xterm-color
  :defer t)

;;; Eglot (LSP) -- built-in Emacs 29+
;; Provides: M-. (jump-to-def), M-? (find-references), M-, (jump-back),
;;           eldoc hover, flymake diagnostics, company completions
;; Servers: gopls (Go), pyright (Python), clangd (C/C++)

(use-package eglot
  :ensure nil
  :hook ((go-mode . eglot-ensure)
         (python-mode . eglot-ensure)
         (c-mode . eglot-ensure)
         (c++-mode . eglot-ensure))
  :config
  (add-to-list 'eglot-server-programs
               '(python-mode . ("pyright-langserver" "--stdio"))))

;;; Go mode

(use-package go-mode
  :mode "\\.go\\'"
  :config
  (setq gofmt-command "goimports")
  (defun my-go-mode-hook ()
    (setq tab-width 4)
    (setq indent-tabs-mode nil))
  (add-hook 'go-mode-hook #'my-go-mode-hook)
  (add-hook 'before-save-hook #'gofmt-before-save))

;;; Markdown mode

(use-package markdown-mode
  :mode (("\\.markdown\\'" . markdown-mode)
         ("\\.md\\'" . markdown-mode)
         ("README\\.md\\'" . gfm-mode)))

;;; C/C++ (built-in cc-mode, no require needed)

(with-eval-after-load 'cc-mode
  (nconc c-style-alist
    '(("josh"
       (c-basic-offset . 4)
       (c-tab-always-indent . nil)
       (c-hanging-comment-ender-p . nil)
       (c-offsets-alist . (
                           (case-label . +2)
                           (access-label . -2)
                           (label . 0)
                           (defun-block-intro . +)
                           (statement-block-intro . +)
                           (statement-case-intro . +2)
                           (statement-case-open . +2)
                           (substatement-open . 0)
                           (inline-open . 0)
                           (block-open . -)
                           (brace-list-intro . 0)
                           (brace-list-entry . +))))))

  (defun c-semi&comma-no-newlines-before-nonblanks ()
    (save-excursion
      (if (and (eq last-command-event ?\;)
               (zerop (forward-line 1))
               (not (looking-at "^[ \t]*$")))
          'stop
        nil)))

  (setq c-hanging-semi&comma-criteria
        (list 'c-semi&comma-no-newlines-before-nonblanks
              'c-semi&comma-inside-parenlist
              'c-semi&comma-no-newlines-for-oneline-inliners))

  (defun flip-c-style-hook ()
    (c-set-style "josh")
    (setq c-auto-newline nil)
    (turn-on-auto-fill)
    (setq tab-width 4)
    (setq indent-tabs-mode nil)
    (setq c-tab-always-indent nil)
    (setq comment-multi-line t)
    (setq c-comment-continuation-stars "* ")
    (define-key c-mode-base-map "\C-m" 'c-context-line-break))
  (add-hook 'c-mode-common-hook #'flip-c-style-hook))

;;; Java

(with-eval-after-load 'cc-mode
  (c-add-style "java-josh"
               (list '(c-basic-offset . 4)
                     '(c-comment-only-line-offset 0 . 0)
                     '(c-hanging-comment-starter-p . t)
                     (list 'c-offsets-alist
                           '(access-label . 0)
                           '(arglist-close . c-lineup-arglist)
                           '(arglist-intro . c-lineup-arglist-intro-after-paren)
                           '(block-close . 0)
                           '(class-open . 0)
                           '(class-close . 0)
                           '(defun-block-intro . +)
                           '(func-decl-cont . c-lineup-java-throws)
                           '(inher-cont . c-lineup-java-inher)
                           '(inline-open . 0)
                           '(knr-argdecl-intro . 5)
                           '(label . 0)
                           '(statement-block-intro . +)
                           '(statement-case-open . +)
                           '(statement-cont . +)
                           '(substatement-open . 0)
                           '(topmost-intro . 0)
                           '(topmost-intro-cont . +))))

  (defun flip-java-style-hook ()
    (c-set-style "java-josh")
    (setq c-auto-newline t)
    (turn-on-auto-fill)
    (setq tab-width 4)
    (setq c-tab-always-indent nil)
    (setq comment-multi-line t)
    (setq c-comment-continuation-stars "* "))
  (add-hook 'java-mode-hook #'flip-java-style-hook))

;;; C/C++ auto-mode-alist

(setq auto-mode-alist
      (append
       '(("\\.C$"   . c++-mode)
         ("\\.H$"   . c++-mode)
         ("\\.cc$"  . c++-mode)
         ("\\.cpp$" . c++-mode)
         ("\\.hh$"  . c++-mode)
         ("\\.c$"   . c-mode)
         ("\\.h$"   . c++-mode))
       auto-mode-alist))

;;; Global keybindings

(define-key global-map "\C-x\C-b" 'josh-buffer-menu)
(define-key global-map "\e#" 'replace-string)
(define-key global-map "\C-xz" 'repeat-complex-command)
(define-key global-map "\C-xc" 'compile)
(define-key global-map "\C-x`" 'next-error)
(define-key global-map "\C-x~" 'goto-line)
(define-key global-map [delete] 'delete-char)
(add-hook 'lisp-mode-hook (lambda ()
      (local-set-key (kbd "RET") 'newline-and-indent)))
(define-key global-map (kbd "RET") 'newline-and-indent)

;;; Match-paren on backtick

(global-set-key "`" 'match-paren)
(defun match-paren (arg)
  "Go to the matching parenthesis if on parenthesis otherwise insert `."
  (interactive "p")
  (cond ((looking-at "\\s\(") (forward-list 1) (backward-char 1))
        ((looking-at "\\s\)") (forward-char 1) (backward-list 1))
        (t (self-insert-command (or arg 1)))))

;;; Compilation

(setq compilation-scroll-output t)

(defun compile-with-temp-command ()
  "Compile without retaining the compile command used."
  (interactive)
  (let ((compile-command compile-command))
    (call-interactively 'compile)))

;;; dotemacs ends here
